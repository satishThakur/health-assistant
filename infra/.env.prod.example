# Copy to .env.prod on the EC2 instance and fill in real values
# Never commit .env.prod to git

DB_USER=healthuser
DB_PASSWORD=change_me_strong_password
DB_NAME=health_assistant

# Min 32 chars, random string
JWT_SECRET=change_me_at_least_32_chars_long_random

# From GoogleService-Info.plist (CLIENT_ID field)
GOOGLE_CLIENT_ID=

# Shared secret between backend and Garmin scraper
GARMIN_INGEST_SECRET=change_me_strong_random_secret
